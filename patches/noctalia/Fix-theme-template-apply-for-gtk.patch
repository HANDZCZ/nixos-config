From: HANDZCZ <handz@email.cz>
Date: Thu, 12 Mar 2026 20:33:38 +0100
Subject: [PATCH] Fix theme template apply for gtk

---
 Scripts/python/src/theming/gtk-refresh.py | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/Scripts/python/src/theming/gtk-refresh.py b/Scripts/python/src/theming/gtk-refresh.py
index 436bf91f0..5d680c80e 100644
--- a/Scripts/python/src/theming/gtk-refresh.py
+++ b/Scripts/python/src/theming/gtk-refresh.py
@@ -53,9 +53,10 @@ def ensure_gtk_css_import(gtk_css: Path, colors_file: Path, label: str) -> bool:
         print(f"Error: {label} noctalia.css not found at {colors_file}", file=sys.stderr)
         return False
 
-    # If gtk.css is a symlink, replace it with a regular file
     if gtk_css.is_symlink():
-        gtk_css.unlink()
+        # If it is a symlink don't do anything
+        # Fixes: Existing file '...' would be clobbered by backing up '...'
+        return True
 
     if gtk_css.exists():
         content = gtk_css.read_text()
